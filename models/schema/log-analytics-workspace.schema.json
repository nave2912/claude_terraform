{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://internal/schemas/log-analytics-workspace.schema.json",
  "title": "Log Analytics Workspace Model",
  "description": "Schema for JSON-driven Azure Log Analytics Workspace definitions consumed by environments/<env>/main.tf",
  "type": "object",
  "required": ["log_analytics_workspaces"],
  "additionalProperties": false,
  "properties": {
    "log_analytics_workspaces": {
      "type": "object",
      "description": "Map keyed by a stable logical id. The key becomes the for_each key in Terraform.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name", "resource_group_name", "tags"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9-]{4,63}$",
            "description": "Workspace name, 4-63 chars, alphanumeric and hyphens only."
          },
          "resource_group_name": {
            "type": "string",
            "minLength": 1,
            "description": "Name of the resource group (must match the \"name\" of an entry in resource-group.json) to deploy into. Location is inherited from that resource group."
          },
          "sku": {
            "type": "string",
            "default": "PerGB2018"
          },
          "retention_in_days": {
            "type": "integer",
            "minimum": 30,
            "maximum": 730,
            "default": 30,
            "description": "30 is the platform minimum for PerGB2018 and the cheapest option."
          },
          "tags": {
            "type": "object",
            "required": [
              "environment",
              "owner",
              "costCenter",
              "application",
              "dataClassification"
            ],
            "properties": {
              "environment": { "type": "string", "enum": ["dev", "qa", "prod"] },
              "owner": { "type": "string", "minLength": 1 },
              "costCenter": { "type": "string", "minLength": 1 },
              "application": { "type": "string", "minLength": 1 },
              "dataClassification": {
                "type": "string",
                "enum": ["public", "internal", "confidential", "restricted"]
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
