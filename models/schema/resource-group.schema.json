{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://internal/schemas/resource-group.schema.json",
  "title": "Resource Group Model",
  "description": "Schema for JSON-driven Azure Resource Group definitions consumed by environments/<env>/main.tf",
  "type": "object",
  "required": ["resource_groups"],
  "additionalProperties": false,
  "properties": {
    "resource_groups": {
      "type": "object",
      "description": "Map keyed by a stable logical id. The key becomes the for_each key in Terraform.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name", "location", "tags"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Must follow naming convention: <workload>-<env> (lowercase, hyphen-separated)"
          },
          "location": {
            "type": "string",
            "minLength": 3
          },
          "tags": {
            "type": "object",
            "required": [
              "environment",
              "owner",
              "costCenter",
              "application",
              "dataClassification"
            ],
            "properties": {
              "environment": { "type": "string", "enum": ["dev", "qa", "prod"] },
              "owner": { "type": "string", "minLength": 1 },
              "costCenter": { "type": "string", "minLength": 1 },
              "application": { "type": "string", "minLength": 1 },
              "dataClassification": {
                "type": "string",
                "enum": ["public", "internal", "confidential", "restricted"]
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
