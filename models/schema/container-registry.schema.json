{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://internal/schemas/container-registry.schema.json",
  "title": "Container Registry Model",
  "description": "Schema for JSON-driven Azure Container Registry definitions consumed by environments/<env>/main.tf",
  "type": "object",
  "required": ["container_registries"],
  "additionalProperties": false,
  "properties": {
    "container_registries": {
      "type": "object",
      "description": "Map keyed by a stable logical id. The key becomes the for_each key in Terraform.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name", "resource_group_key", "tags"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9]{5,50}$",
            "description": "Registry name, 5-50 alphanumeric characters only, globally unique."
          },
          "resource_group_key": {
            "type": "string",
            "minLength": 1,
            "description": "Logical id of the resource group (key under resource_groups in resource-group.json) to deploy into. Location is inherited from that resource group."
          },
          "sku": {
            "type": "string",
            "enum": ["Basic", "Standard", "Premium"],
            "default": "Basic"
          },
          "admin_enabled": {
            "type": "boolean",
            "default": false,
            "description": "Should stay false — consumers pull images via managed identity + AcrPull instead of registry admin credentials."
          },
          "tags": {
            "type": "object",
            "required": [
              "environment",
              "owner",
              "costCenter",
              "application",
              "dataClassification"
            ],
            "properties": {
              "environment": { "type": "string", "enum": ["dev", "qa", "prod"] },
              "owner": { "type": "string", "minLength": 1 },
              "costCenter": { "type": "string", "minLength": 1 },
              "application": { "type": "string", "minLength": 1 },
              "dataClassification": {
                "type": "string",
                "enum": ["public", "internal", "confidential", "restricted"]
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
