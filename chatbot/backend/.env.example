# This file (.env.example) IS tracked in git — it's a template, never put a
# real value here. Copy it to .env.local instead (only .env and .env.local
# are gitignored — see ../.gitignore) and put the real key there.

ANTHROPIC_API_KEY=

# Required to run `npm run serve` (the HTTP API) — the server refuses to
# start without it. Choose any long random value; send it back on every
# request as the x-api-key header.
API_KEY=

# Optional. Comma-separated. Defaults to "dev" if unset.
ALLOWED_ENVIRONMENTS=dev

# Optional. Defaults to 3000.
PORT=
