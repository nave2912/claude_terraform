# This file (.env.example) IS tracked in git — it's a template, never put a
# real value here. Copy it to .env.local instead (only .env and .env.local
# are gitignored — see ../.gitignore) and put the real key there.

ANTHROPIC_API_KEY=

# Required to run `npm run serve` (the HTTP API) — the server refuses to
# start without it. Choose any long random value; send it back on every
# request as the x-api-key header.
API_KEY=

# Optional. Comma-separated. Defaults to "dev" if unset.
ALLOWED_ENVIRONMENTS=dev

# Optional. Defaults to 3000.
PORT=

# Required only for /keyvault routes (writing secrets directly to Azure Key
# Vault, bypassing the git/PR pipeline entirely). Needs an Entra ID app
# registration/service principal with the "Key Vault Secrets Officer" RBAC
# role assigned on each vault it should manage (modules/key_vault/main.tf
# sets enable_rbac_authorization = true, so a role assignment is required —
# access policies won't work). If unset, /keyvault/* routes return 503 but
# the rest of the server still runs normally.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
