# This file (.env.example) IS tracked in git — never put a real value here.
# Copy it to .env.local instead (gitignored by default in Next.js).

# The Express chatbot backend (chatbot/backend) this frontend proxies to.
# All calls to it happen server-side (Next.js Route Handlers under
# src/app/api/backend/*), never from the browser — so BACKEND_API_KEY never
# ships in the client bundle.
BACKEND_BASE_URL=https://chatbot-backend--tstz27t.ambitiousriver-66b6f5ba.eastus.azurecontainerapps.io
BACKEND_API_KEY=

# Used only by src/app/api/intent/route.ts (server-side) to turn a free-text
# "which resource do you need?" message into a resourceType selection. This
# is the ONLY place an LLM is involved on the frontend; it never produces
# the fields submitted to the backend — those always come from the
# schema-driven form, validated client-side with zod before submit.
ANTHROPIC_API_KEY=
